# .gitignore for a Python project using TensorFlow, Tkinter, and PyInstaller

# --- Python bytecode and cache ---
# These files are generated automatically by Python during runtime.
# They are not needed in the repository as they can be regenerated.
__pycache__/
*.pyc
*.pyo
*.pyd

# --- Virtual Environments ---
# If you use a virtual environment (which is a best practice),
# you should never commit the environment folder itself.
# The `requirements.txt` file is used to recreate the environment.
venv/
env/
.venv/
.env/

# --- Packaging and Distribution Artifacts ---
# These folders are created by tools like PyInstaller and setuptools when you build or package your application.
# The final distributable (like the .exe) should be uploaded to GitHub Releases, not the main repository.
dist/
build/
*.egg-info/
*.egg
wheels/
sdist/
downloads/
parts/
.Python

# --- IDE and Editor specific files ---
# These folders store your personal editor settings and should not be shared.
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# --- OS-specific files ---
# Files generated automatically by your operating system.
.DS_Store  # macOS
Thumbs.db  # Windows
._*

# --- Log and temporary files ---
*.log
*.tmp
*.swp
